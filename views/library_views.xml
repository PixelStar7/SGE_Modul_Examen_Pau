<?xml version="1.0" encoding="utf-8"?>

<odoo>

    <!-- Estructura de navegació Superior -->
    <menuitem name="Library" id="menu_root"/>

    <menuitem name="Configuration" id="menu_configuration" parent="menu_root" sequence="100"/>
    

    <!-- GESTIÓ DE ITEM CATEGORY -->

    <!-- Vista Llista Item Category -->
    <record model="ir.ui.view" id="library_item_category_list">
        <field name="name">library.item.category.list</field>
        <field name="model">library.item.category</field>
        <field name="arch" type="xml">
            <list string="Item Categories">
                <field name="name"></field>
                <field name="parent_id"></field>
                <field name="isbn"></field>
                <field name="issn"></field>
            </list>
        </field>
    </record>

    <!-- Vista Formulari Item Category -->
    

    <!-- Acció-->
    <record model="ir.actions.act_window" id="library_item_category_action">
        <field name="name">ItemCategories</field>
        <field name="res_model">library.item.category</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Submenu -->
    <menuitem name="Item Categories" id="menu_item_categories" parent="menu_root" sequence="10" action="library_item_category_action"/>

</odoo>