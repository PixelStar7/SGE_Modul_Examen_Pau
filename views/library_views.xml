<?xml version="1.0" encoding="utf-8"?>

<odoo>

    <!-- Estructura de navegació Superior -->
    <menuitem name="Library" id="menu_root"/>

    <menuitem name="Configuration" id="menu_configuration" parent="menu_root" sequence="100"/>
    
    <!-- Vista Llista Author -->
    <record model="ir.ui.view" id="library_author_list">
        <field name="name">library.author.list</field>
        <field name="model">library.author</field>
        <field name="arch" type="xml">
            <list string="Authors">
                <field name="display_name" string="Full Name"></field>
                <field name="country_id" string="Citizenship"></field>
                <field name="birthdate"></field>
                <field name="deathdate"></field>
            </list>
        </field>
    </record>

    <!-- Vista Form d'Author -->
    <record model="ir.ui.view" id="library_author_form">
        <field name="name">library.author.form</field>
        <field name="model">library.author</field>
        <field name="arch" type="xml">
            <form string="Author">
                <sheet>
                    <group col="8">
                        <group>
                            <field name="last_name"></field>
                            <field name="first_name"></field>
                            <field name="country_id"></field>
                        </group>

                        <group>
                            <field name="birthdate"></field>
                            <field name="deathdate"></field>
                        </group>
                    </group>
                    <group string="ITEMS">
                        <field name="item_ids" nolabel="1">
                            <list>
                                <field name="reference"></field>
                                <field name="category_id"></field>
                                <field name="title"></field>
                            </list>
                        </field>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Acció Author -->
    <record model="ir.actions.act_window" id="library_author_action">
        <field name="name">Authors</field>
        <field name="res_model">library.author</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Submenu Author -->
    <menuitem name="Authors" id="menu_authors" parent="menu_root" sequence="10" action="library_author_action"/>


    <!-- Vista Llista Item Category -->
    <record model="ir.ui.view" id="library_item_category_list">
        <field name="name">library.item.category.list</field>
        <field name="model">library.item.category</field>
        <field name="arch" type="xml">
            <list string="Item Categories">
                <field name="name"></field>
                <field name="parent_id"></field>
                <field name="isbn"></field>
                <field name="issn"></field>
            </list>
        </field>
    </record>

    <!-- Vista Formulari Item Category -->
    <record model="ir.ui.view" id="library_item_category_form">
        <field name="name">library.item.category.form</field>
        <field name="model">library.item.category</field>
        <field name="arch" type="xml">
            <form string="Item Category">
                <sheet>
                    <group col="8">
                        <group>
                            <field name="name"></field>
                            <field name="parent_id"></field>
                        </group>

                        <group>
                            <field name="isbn"></field>
                            <field name="issn"></field>
                        </group>
                    </group>

                    <group string="SUBCATEGORIES">
                        <field name="child_ids" nolabel="1" readonly="0" widget="many2many">
                            <list delete="0">
                                <field name="name"></field>
                                <field name="isbn"></field>
                                <field name="issn"></field>
                            </list>
                            <form>
                                <group>
                                    <group>
                                        <field name="name"></field>
                                    </group>
                                    <group>
                                        <field name="isbn"></field>
                                        <field name="issn"></field>
                                    </group>
                                </group>
                            </form>
                        </field>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Acció Item Category -->
    <record model="ir.actions.act_window" id="library_item_category_action">
        <field name="name">ItemCategories</field>
        <field name="res_model">library.item.category</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Submenu Item Category -->
    <menuitem name="Item Categories" id="menu_item_categories" parent="menu_configuration" action="library_item_category_action"/>



    <!-- Vista Llista Item -->
    <record model="ir.ui.view" id="library_item_list">
        <field name="name">library.item.list</field>
        <field name="model">library.item</field>
        <field name="arch" type="xml">
            <list string="Items">
                <field name="reference"></field>
                <field name="title"></field>
                <field name="category_id"></field>
            </list>
        </field>
    </record>

    <!-- Vista Form d'Item -->
     <record model="ir.ui.view" id="library_item_form">
        <field name="name">library.item.form</field>
        <field name="model">library.item</field>
        <field name="arch" type="xml">
            <form string="Item">
                <sheet>
                    <group>
                        <group string="ITEM">
                            <group colspan="2">
                                <field name="reference"/>
                                <field name="category_id"/>
                            </group>

                            <group>
                                <field name="title"/>
                            </group>
                        </group>

                        <group string="DESCRIPTION" col="4">
                            <field name="description" nolabel="1" colspan="4" widget="html" options="{'resizable':true}" placeholder="Lorem ipsum sit amet..."></field>
                        </group>
                    </group>

                    <group col="8">
                        <group string="INPUT DATA" col="2">
                            <field name="date_in"></field>
                        </group>

                        <group string="OUTPUT DATA" col="2">
                            <field name="date_out"></field>
                            <field name="reason"></field>
                        </group>

                        <group string="AUTHORS" colspan="3">
                            <field name="author_ids" nolabel="1" widget="many2many">
                                <list create="0" delete="0">
                                    <field name="display_name" string="Full Name"></field>
                                    <field name="birthdate"></field>
                                </list>
                            </field>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Acció Item -->
    <record model="ir.actions.act_window" id="library_item_action">
        <field name="name">Items</field>
        <field name="res_model">library.item</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Submenu Item -->
    <menuitem name="Items" id="menu_items" parent="menu_configuration" action="library_item_action"/>
    
</odoo>